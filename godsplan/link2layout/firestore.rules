rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users can read/write their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Items are readable by anyone, writable by any authenticated user (CMS mode)
    match /items/{itemId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Saved plans are readable by anyone, writable by authenticated users
    match /saved_plans/{planId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Reviews are readable by anyone, writable by authenticated users
    match /reviews/{reviewId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Alerts are readable by anyone, writable/deletable by authenticated users
    match /alerts/{alertId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
